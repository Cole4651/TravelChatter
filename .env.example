# Copy this to .env and fill in values. Never commit .env.

# MongoDB connection string (Atlas or local).
MONGODB_URI=mongodb://127.0.0.1:27017/travelchatter

# Long random string. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_secret

# Groq API key (https://console.groq.com). Leave blank to disable AI features.
GROQ_API_KEY=

# Optional. Defaults to 3000.
PORT=3000
